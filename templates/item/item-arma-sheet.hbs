<form class="{{cssClass}} jem-gear-sheet jem-weapon-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" draggable="true" data-uuid="{{item.uuid}}" />
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{item.name}}" placeholder="Nome da Arma"/></h1>
      <div class="item-meta grid grid-2col">
        <div class="weapon-header">
          <div class="weapon-meta">
            <div class="meta-row"><strong>Empunhadura:</strong> {{system.ataque.detalhes.empunhadura.value}}</div>
            <div class="meta-row"><strong>Alcance:</strong> {{system.ataque.alcance.valor.value}}{{system.ataque.alcance.unidade.value}}</div>
            <div class="meta-row"><strong>Dano:</strong> {{scaledDamage}} {{system.damage.bonus.value}} ({{system.damage.type.value}})</div>
          </div>
        </div>
      </div>
    </div>
    <a class="header-button control close" role="button" title="Fechar">
      <i class="fas fa-times"></i>&nbsp;Fechar
    </a>
  </header>

  {{! Sheet Tab Navigation }}
  <nav class='sheet-tabs tabs' data-group='primary'>
    <a class='item' data-tab='ataque'>Ataque</a>
    <a class='item' data-tab='dano'>Dano</a>
    <a class='item' data-tab='encantamentos'>Encantamentos</a>
    <a class='item' data-tab='descricao'>Descrição</a>
  </nav>

  <section class='sheet-body'>
    <div class='tab' data-group='primary' data-tab='ataque'>
      <fieldset class="attack-fieldset">
        <legend>Ataque</legend>
        <div class="weapon-attributes grid grid-2col">
          <div class="field">
            <label>Atributo</label>
            <select name="system.ataque.atributo.value">
              <option value="forca" {{#if (eq system.ataque.atributo.value "forca")}}selected{{/if}}>Força</option>
              <option value="destreza" {{#if (eq system.ataque.atributo.value "destreza")}}selected{{/if}}>Destreza</option>
            </select>
          </div>
          <div class="field">
            <label>Perícia</label>
            <select name="system.ataque.pericia.value">
              <option value="">— Nenhuma —</option>
              {{#each actorPericiasList}}
                <option value="{{this.key}}" {{#if (eq ../system.ataque.pericia.value this.key)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>
          <div class="field">
            <label>Bônus de Ataque</label>
            <input type="number" name="system.ataque.bonus.value" value="{{system.ataque.bonus.value}}"/>
          </div>
          <div class="field">
            <label>Alcance (m)</label>
            <input type="number" step="0.5" name="system.ataque.alcance.valor.value" value="{{system.ataque.alcance.valor.value}}"/>
          </div>
          <div class="field">
            <label>Crítico (Ameaça / Mult.)</label>
            <div style="display:flex; gap:6px; align-items:center;">
              <input class="small" type="number" min="1" max="20" name="system.ataque.critico.min.value" value="{{system.ataque.critico.min.value}}"/>
              <span style="opacity:0.7;">/ x</span>
              <input class="small" type="number" min="1" name="system.ataque.critico.mult.value" value="{{system.ataque.critico.mult.value}}"/>
            </div>
          </div>
          <div class="field">
            <label>Empunhadura</label>
            <select name="system.ataque.detalhes.empunhadura.value">
              <option value="uma mão" {{#if (eq system.ataque.detalhes.empunhadura.value "uma mão")}}selected{{/if}}>Uma Mão</option>
              <option value="duas mãos" {{#if (eq system.ataque.detalhes.empunhadura.value "duas mãos")}}selected{{/if}}>Duas Mãos</option>
              <option value="versátil" {{#if (eq system.ataque.detalhes.empunhadura.value "versátil")}}selected{{/if}}>Versátil</option>
            </select>
          </div>
          <div class="field">
            <label>Tipo de Arma</label>
            <select name="system.ataque.detalhes.tipo.value">
              <option value="impacto" {{#if (eq system.ataque.detalhes.tipo.value "impacto")}}selected{{/if}}>Impacto</option>
              <option value="corte" {{#if (eq system.ataque.detalhes.tipo.value "corte")}}selected{{/if}}>Corte</option>
              <option value="perfurante" {{#if (eq system.ataque.detalhes.tipo.value "perfurante")}}selected{{/if}}>Perfurante</option>
              <option value="longa distância" {{#if (eq system.ataque.detalhes.tipo.value "longa distância")}}selected{{/if}}>Longa Distância</option>
            </select>
          </div>
          <div class="field">
            <label>Grau</label>
            <input type="number" min="0" name="system.ataque.detalhes.grau.value" value="{{system.ataque.detalhes.grau.value}}"/>
          </div>
        </div>
        <div class="actions-row">
          <button type="button" class="roll-button test-attack">Testar Ataque</button>
        </div>
      </fieldset>
    </div>

    <div class='tab' data-group='primary' data-tab='dano'>
      <fieldset class="damage-fieldset">
        <legend>Dano</legend>
        <div class="weapon-attributes grid grid-2col">
          <div class="field">
            <label>Dano Base</label>
            <input type="text" name="system.damage.base.value" value="{{system.damage.base.value}}" placeholder="1d6"/>
          </div>
          <div class="field">
            <label>Bônus de Dano</label>
            <input type="text" name="system.damage.bonus.value" value="{{system.damage.bonus.value}}" placeholder="@forca"/>
          </div>
          <div class="field">
            <label>Tipo de Dano</label>
            <input type="text" name="system.damage.type.value" value="{{system.damage.type.value}}" placeholder="corte, impacto, fogo..."/>
          </div>
          <div class="field">
            <label>Aumento de Nível</label>
            <input type="number" name="system.damage.levelBoost.value" value="{{system.damage.levelBoost.value}}"/>
          </div>
          <div class="field">
            <label>Dano na Alma</label>
            <input type="checkbox" name="system.damage.isSoulDamage.value" {{checked system.damage.isSoulDamage.value}}/>
          </div>
        </div>
        <div class="actions-row">
          <button type="button" class="roll-button test-damage">Testar Dano</button>
          <div class="muted">Preview: <span class="preview-damage">{{scaledDamage}} {{system.damage.bonus.value}}</span></div>
        </div>
      </fieldset>
    </div>

    <div class='tab' data-group='primary' data-tab='encantamentos'>
      <fieldset class="enchantment-fieldset">
        <legend>Ferramenta Amaldiçoada</legend>

        <div class="weapon-attributes grid grid-2col">
          <div class="field">
            <label>Grau da Ferramenta</label>
            <select name="system.ferramenta.grau.value">
              <option value="">— Nenhum (Arma Comum) —</option>
              {{#each ferramenta.grauOptions}}
                <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>
          {{#if ferramenta.isFerramenta}}
            <div class="field">
              <label>Cargas de Encantamento</label>
              <div style="display:flex; gap:6px; align-items:center;">
                <input type="number" min="0" name="system.ferramenta.cargas.value" value="{{ferramenta.cargas.value}}" style="width:60px;"/>
                <span style="opacity:0.7;">/</span>
                <input type="number" min="0" name="system.ferramenta.cargas.max" value="{{ferramenta.cargas.max}}" style="width:60px;"/>
              </div>
            </div>
          {{/if}}
        </div>

        {{#if ferramenta.isFerramenta}}
          {{#if ferramenta.grauInfo}}
            <div class="note" style="margin-top:8px; padding:8px; background:rgba(157,78,221,0.1); border-radius:6px;">
              <strong>{{ferramenta.grauInfo.label}}</strong> —
              Bônus de Dano: <strong>+{{ferramenta.grauInfo.bonusDano}}</strong> |
              Encantamentos acumulados: <strong>{{ferramenta.totalSlots}}</strong>
              (usando {{ferramenta.currentCount}})
            </div>
          {{/if}}

          {{#if ferramenta.isEspecial}}
            <div class="field" style="margin-top:10px;">
              <label>Habilidade Única (Grau Especial)</label>
              <textarea name="system.ferramenta.habilidadeUnica.value" rows="3" style="width:100%;">{{ferramenta.habilidadeUnica}}</textarea>
            </div>
          {{/if}}

          <h4 style="margin-top:12px;">Encantamentos Ativos</h4>
          {{#if ferramenta.selectedEncantamentos.length}}
            <div class="enchantment-list" style="display:flex; flex-direction:column; gap:6px; margin-top:6px;">
              {{#each ferramenta.selectedEncantamentos}}
                <div class="enchantment-entry" style="padding:8px; background:rgba(111,66,193,0.12); border:1px solid rgba(157,78,221,0.3); border-radius:6px; display:flex; justify-content:space-between; align-items:flex-start;">
                  <div>
                    <strong>{{this.nome}}</strong>
                    <div style="font-size:0.85rem; opacity:0.85; margin-top:2px;">{{this.descricao}}</div>
                    {{#if this.preRequisito}}
                      <div style="font-size:0.8rem; color:#d4a017; margin-top:2px;"><em>Pré-requisito: {{this.preRequisito}}</em></div>
                    {{/if}}
                  </div>
                  <button type="button" class="remove-encantamento" data-key="{{this.key}}" title="Remover" style="background:none; border:none; color:#f44; cursor:pointer; font-size:1rem; padding:4px;">
                    <i class="fas fa-times"></i>
                  </button>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="note" style="margin-top:6px;">Nenhum encantamento aplicado.</p>
          {{/if}}

          {{#if ferramenta.availableEncantamentos.length}}
            <div style="margin-top:10px; display:flex; gap:6px; align-items:center;">
              <select class="encantamento-select" style="flex:1;">
                <option value="">— Selecionar Encantamento —</option>
                {{#each ferramenta.availableEncantamentos}}
                  <option value="{{this.key}}">{{this.nome}}{{#if this.preRequisito}} (Req: {{this.preRequisito}}){{/if}}</option>
                {{/each}}
              </select>
              <button type="button" class="add-encantamento" style="white-space:nowrap;">
                <i class="fas fa-plus"></i> Adicionar
              </button>
            </div>
          {{/if}}
        {{/if}}
      </fieldset>
    </div>

    <div class='tab' data-group='primary' data-tab='descricao'>
      <div class="editor-container">
        {{editor system.descricao.value target="system.descricao.value" engine="prosemirror" button=true owner=owner editable=editable}}
      </div>
    </div>
  </section>

  <footer class="sheet-footer">
    <div class="footer-controls" style="display:flex; align-items:center; gap:12px;">
      <button type="submit" class="jem-btn jem-btn--primary">Salvar</button>
    </div>
  </footer>
</form>
