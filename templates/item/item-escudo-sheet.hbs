<form class="{{cssClass}} jem-gear-sheet jem-shield-sheet" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" draggable="true" data-uuid="{{item.uuid}}" />
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{item.name}}" placeholder="Nome do Escudo"/></h1>
      <div class="item-meta grid grid-2col">
        <div>
          <label>Fonte</label>
          <input type="text" name="system.fonte.value" value="{{system.fonte.value}}" placeholder="Ex: Livro / Mestre"/>
        </div>
        <div>
          <label>Requisito</label>
          <input type="text" name="system.requisito.value" value="{{system.requisito.value}}" placeholder="Ex: Rank / Permissão"/>
        </div>
      </div>
    </div>
    <a class="header-button control close" role="button" title="Fechar">
      <i class="fas fa-times"></i>&nbsp;Fechar
    </a>
  </header>

  {{! Sheet Tab Navigation }}
  <nav class='sheet-tabs tabs' data-group='primary'>
    <a class='item' data-tab='descricao'>Descrição</a>
    <a class='item' data-tab='opcoes'>Opções</a>
    <a class='item' data-tab='encantamentos'>Encantamentos</a>
  </nav>

  <section class='sheet-body'>
    <div class='tab' data-group='primary' data-tab='descricao'>
      <div class="editor-container">
        {{editor system.descricao.value target="system.descricao.value" engine="prosemirror" button=true owner=owner editable=editable}}
      </div>
    </div>

    <div class='tab attributes' data-group='primary' data-tab='opcoes'>
      <h3 class="item-section-title">Personalização e Mecânicas</h3>

      <div class="field">
        <label>Tipo de Escudo</label>
        <select name="system.escudo.tipo">
          <option value="normal" {{#if (eq system.escudo.tipo "normal")}}selected{{/if}}>Escudo Normal</option>
          <option value="reforcado" {{#if (eq system.escudo.tipo "reforcado")}}selected{{/if}}>Escudo Reforçado</option>
          <option value="tatico" {{#if (eq system.escudo.tipo "tatico")}}selected{{/if}}>Escudo Tático</option>
        </select>
      </div>

      <div class="field">
        <label>Equipável</label>
        <select name="system.equipado">
          <option value="">— Nenhum —</option>
          <option value="braco" {{#if (eq system.equipado "braco")}}selected{{/if}}>Braço (Off-Hand)</option>
        </select>
      </div>

      <div class="field">
        <label>Bônus (texto)</label>
        <input type="text" name="system.escudo.bonusText" value="{{system.escudo.bonusText}}" placeholder="ex: resistente; reforçado" />
      </div>

      <div class="field">
        <label>Bônus de CA (numérico, opcional)</label>
        <input type="number" name="system.escudo.bonusCa" value="{{system.escudo.bonusCa}}" placeholder="ex: 1" step="1" />
      </div>

      <div class="field">
        <label>Total de CA (calculado)</label>
        <input type="number" name="system.escudo.total" value="{{system.escudo.total}}" readonly />
      </div>

      <p class="note">Como funciona: Escolha o tipo de escudo. Marque como equipado para aplicar o bônus de Defesa. O bônus numérico opcional é somado ao valor base do tipo de escudo.</p>

      <h4 style="margin-top:12px;">Tabela de Tipos de Escudo (valores padrão)</h4>
      <table class="uniform-table" style="width:100%; border-collapse:collapse; margin-top:8px;">
        <thead>
          <tr>
            <th>Tipo</th>
            <th>Bônus de CA</th>
            <th>Penalidade</th>
            <th>Observação</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Escudo Normal</td>
            <td>+2</td>
            <td>0</td>
            <td>N/A</td>
          </tr>
          <tr>
            <td>Escudo Reforçado</td>
            <td>+4</td>
            <td>-1</td>
            <td>Penalidade em perícias de Destreza</td>
          </tr>
          <tr>
            <td>Escudo Tático</td>
            <td>+3</td>
            <td>0</td>
            <td>Concede +1 em Acrobacia</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class='tab' data-group='primary' data-tab='encantamentos'>
      <fieldset class="enchantment-fieldset">
        <legend>Ferramenta Amaldiçoada</legend>

        <div class="weapon-attributes grid grid-2col">
          <div class="field">
            <label>Grau da Ferramenta</label>
            <select name="system.ferramenta.grau.value">
              <option value="">— Nenhum (Escudo Comum) —</option>
              {{#each ferramenta.grauOptions}}
                <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>
          {{#if ferramenta.isFerramenta}}
            <div class="field">
              <label>Cargas de Encantamento</label>
              <div style="display:flex; gap:6px; align-items:center;">
                <input type="number" min="0" name="system.ferramenta.cargas.value" value="{{ferramenta.cargas.value}}" style="width:60px;"/>
                <span style="opacity:0.7;">/</span>
                <input type="number" min="0" name="system.ferramenta.cargas.max" value="{{ferramenta.cargas.max}}" style="width:60px;"/>
              </div>
            </div>
          {{/if}}
        </div>

        {{#if ferramenta.isFerramenta}}
          {{#if ferramenta.grauInfo}}
            <div class="note" style="margin-top:8px; padding:8px; background:rgba(157,78,221,0.1); border-radius:6px;">
              <strong>{{ferramenta.grauInfo.label}}</strong> —
              RD Físico: <strong>{{ferramenta.grauInfo.rdFisico}}</strong> |
              Encantamentos acumulados: <strong>{{ferramenta.totalSlots}}</strong>
              (usando {{ferramenta.currentCount}})
            </div>
          {{/if}}

          {{#if ferramenta.isEspecial}}
            <div class="field" style="margin-top:10px;">
              <label>Habilidade Única (Grau Especial)</label>
              <textarea name="system.ferramenta.habilidadeUnica.value" rows="3" style="width:100%;">{{ferramenta.habilidadeUnica}}</textarea>
            </div>
          {{/if}}

          <h4 style="margin-top:12px;">Encantamentos Ativos</h4>
          {{#if ferramenta.selectedEncantamentos.length}}
            <div class="enchantment-list" style="display:flex; flex-direction:column; gap:6px; margin-top:6px;">
              {{#each ferramenta.selectedEncantamentos}}
                <div class="enchantment-entry" style="padding:8px; background:rgba(111,66,193,0.12); border:1px solid rgba(157,78,221,0.3); border-radius:6px; display:flex; justify-content:space-between; align-items:flex-start;">
                  <div>
                    <strong>{{this.nome}}</strong>
                    <div style="font-size:0.85rem; opacity:0.85; margin-top:2px;">{{this.descricao}}</div>
                    {{#if this.preRequisito}}
                      <div style="font-size:0.8rem; color:#d4a017; margin-top:2px;"><em>Pré-requisito: {{this.preRequisito}}</em></div>
                    {{/if}}
                  </div>
                  <button type="button" class="remove-encantamento" data-key="{{this.key}}" title="Remover" style="background:none; border:none; color:#f44; cursor:pointer; font-size:1rem; padding:4px;">
                    <i class="fas fa-times"></i>
                  </button>
                </div>
              {{/each}}
            </div>
          {{else}}
            <p class="note" style="margin-top:6px;">Nenhum encantamento aplicado.</p>
          {{/if}}

          {{#if ferramenta.availableEncantamentos.length}}
            <div style="margin-top:10px; display:flex; gap:6px; align-items:center;">
              <select class="encantamento-select" style="flex:1;">
                <option value="">— Selecionar Encantamento —</option>
                {{#each ferramenta.availableEncantamentos}}
                  <option value="{{this.key}}">{{this.nome}}{{#if this.preRequisito}} (Req: {{this.preRequisito}}){{/if}}</option>
                {{/each}}
              </select>
              <button type="button" class="add-encantamento" style="white-space:nowrap;">
                <i class="fas fa-plus"></i> Adicionar
              </button>
            </div>
          {{/if}}
        {{/if}}
      </fieldset>
    </div>
  </section>

  <footer class="sheet-footer">
    <div class="footer-controls" style="display:flex; align-items:center; gap:12px;">
      <button type="submit" class="jem-btn jem-btn--primary">Salvar</button>
    </div>
  </footer>
</form>
